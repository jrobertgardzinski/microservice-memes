{
  "consumer": {
    "name": "microservice-memes"
  },
  "interactions": [
    {
      "description": "an introspection of a valid access token",
      "providerStates": [
        {
          "name": "a session for a signed-in user exists"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer valid-session-token"
        },
        "method": "GET",
        "path": "/me"
      },
      "response": {
        "body": {
          "email": "user@example.com",
          "mfaCompliant": true,
          "roles": [
            "USER"
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.mfaCompliant": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.roles": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.roles[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "an introspection of an invalid token",
      "request": {
        "headers": {
          "Authorization": "Bearer invalid-token"
        },
        "method": "GET",
        "path": "/me"
      },
      "response": {
        "status": 401
      }
    }
  ],
  "metadata": {
    "pact-jvm": {
      "version": "4.6.17"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "microservice-security"
  }
}
